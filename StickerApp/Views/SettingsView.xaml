<Window
    x:Class="StickerApp.Views.SettingsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="Settings &amp; Recycle Bin">

    <Grid Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <NavigationView x:Name="SettingsNav" PaneDisplayMode="Left" IsSettingsVisible="False" IsBackButtonVisible="Collapsed">
            <NavigationView.MenuItems>
                <NavigationViewItem Content="General Settings" Icon="Setting" Tag="general" />
                <NavigationViewItem Content="Recycle Bin" Icon="Delete" Tag="recycle" />
            </NavigationView.MenuItems>

            <ScrollViewer Margin="24,24,24,24">
                <StackPanel x:Name="ContentStack" Spacing="24">
                    <!-- General Settings Section -->
                    <StackPanel x:Name="GeneralPanel" Spacing="16" Visibility="Visible">
                        <TextBlock Text="Application Settings" Style="{ThemeResource TitleTextBlockStyle}" />

                        <!-- Theme Selection -->
                        <StackPanel Spacing="8">
                            <TextBlock Text="App Theme" Style="{ThemeResource BodyTextBlockStyle}" FontWeight="SemiBold" />
                            <ComboBox x:Name="ThemeComboBox" Width="200" SelectionChanged="ThemeComboBox_SelectionChanged">
                                <ComboBoxItem Content="System Default" Tag="system" />
                                <ComboBoxItem Content="Light" Tag="light" />
                                <ComboBoxItem Content="Dark" Tag="dark" />
                            </ComboBox>
                        </StackPanel>

                        <!-- Toggles -->
                        <ToggleSwitch x:Name="StartupToggle" Header="Start with Windows" Toggled="StartupToggle_Toggled" />
                        <ToggleSwitch x:Name="TrayToggle" Header="Enable System Tray Icon" Toggled="TrayToggle_Toggled" />
                        <ToggleSwitch x:Name="AnimationsToggle" Header="Enable Window Animations" Toggled="AnimationsToggle_Toggled" />

                        <!-- Actions -->
                        <StackPanel Spacing="8" Margin="0,16,0,0">
                            <TextBlock Text="Maintenance &amp; Backup" Style="{ThemeResource BodyTextBlockStyle}" FontWeight="SemiBold" />
                            <Button Content="Backup Stickers Now" Click="BackupButton_Click" Style="{ThemeResource AccentButtonStyle}" />
                        </StackPanel>
                    </StackPanel>

                    <!-- Recycle Bin Section -->
                    <StackPanel x:Name="RecyclePanel" Spacing="16" Visibility="Collapsed">
                        <TextBlock Text="Recycle Bin (Soft Deleted Stickers)" Style="{ThemeResource TitleTextBlockStyle}" />
                        
                        <ListView x:Name="DeletedStickersList" SelectionMode="None">
                            <ListView.Header>
                                <Grid Margin="12,0,12,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Sticker Details" FontWeight="SemiBold" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" />
                                    <TextBlock Grid.Column="1" Text="Actions" FontWeight="SemiBold" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" Margin="0,0,24,0" />
                                </Grid>
                            </ListView.Header>

                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Grid Padding="12" BorderThickness="0,0,0,1" BorderBrush="{ThemeResource SystemControlPageTextBaseLowBrush}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        
                                        <StackPanel Spacing="4">
                                            <TextBlock Text="{Binding Title}" FontWeight="Bold" FontSize="14" />
                                            <TextBlock Text="{Binding Text}" FontSize="12" TextTrimming="CharacterEllipsis" MaxLines="1" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" />
                                            <TextBlock Text="{Binding DeletedAt, FallbackValue='Unknown date'}" FontSize="10" Foreground="{ThemeResource SystemControlPageTextBaseLowBrush}" />
                                        </StackPanel>

                                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                                            <Button Content="Restore" Click="RestoreButton_Click" Tag="{Binding}" />
                                            <Button Content="Delete Permanently" Click="PurgeButton_Click" Tag="{Binding}" Style="{ThemeResource DefaultButtonStyle}" />
                                        </StackPanel>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </NavigationView>
    </Grid>
</Window>
